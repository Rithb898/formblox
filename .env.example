# Database & Redis (provide your own URLs)
DATABASE_URL=postgresql://user:password@host:5432/dbname
REDIS_URL=redis://:password@host:6379

# URLs (set these to your actual domains in Coolify)
API_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Google OAuth (from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.yourdomain.com/auth/google/callback

# JWT secrets (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Resend (from resend.com)
RESEND_API_KEY=

# OpenAI (used by web for AI form generation / summaries)
OPENAI_API_KEY=
